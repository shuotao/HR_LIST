rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // candidates: logged-in users can write, only admins can read
    match /candidates/{docId} {
      allow write: if request.auth != null;
      allow read: if request.auth != null &&
                     (request.auth.token.email == 'codefortaiwan.com@gmail.com' ||
                      request.auth.token.email == 'shuotao.as@gmail.com');
    }
  }
}
